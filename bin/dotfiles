#!/bin/bash

# color codes
RESTORE='\033[0m'
NC='\033[0m'
BLACK='\033[00;30m'
RED='\033[00;31m'
GREEN='\033[00;32m'
YELLOW='\033[00;33m'
BLUE='\033[00;34m'
PURPLE='\033[00;35m'
CYAN='\033[00;36m'
SEA="\\033[38;5;49m"
LIGHTGRAY='\033[00;37m'
LBLACK='\033[01;30m'
LRED='\033[01;31m'
LGREEN='\033[01;32m'
LYELLOW='\033[01;33m'
LBLUE='\033[01;34m'
LPURPLE='\033[01;35m'
LCYAN='\033[01;36m'
WHITE='\033[01;37m'
OVERWRITE='\e[1A\e[K'

#emoji codes
CHECK_MARK="${GREEN}\xE2\x9C\x94${NC}"
X_MARK="${RED}\xE2\x9C\x96${NC}"
PIN="${RED}\xF0\x9F\x93\x8C${NC}"
CLOCK="${GREEN}\xE2\x8C\x9B${NC}"
ARROW="${SEA}\xE2\x96\xB6${NC}"
BOOK="${RED}\xF0\x9F\x93\x8B${NC}"
HOT="${ORANGE}\xF0\x9F\x94\xA5${NC}"
WARNING="${RED}\xF0\x9F\x9A\xA8${NC}"
RIGHT_ANGLE="${GREEN}\xE2\x88\x9F${NC}"

DOTFILES_LOG="$HOME/.dotfiles.log"

set -e

# Paths
VALUES_DIR="$HOME/.dotfiles/values"
VAULT_SECRET="$HOME/.config/dotfiles/vault-password.txt"
DOTFILES_DIR="$HOME/.dotfiles"
SSH_DIR="$HOME/.ssh"
IS_FIRST_RUN="$HOME/.dotfiles_run"
# _header colorize the given argument with spacing
function _task {
	# if _task is called while a task was set, complete the previous
	if [[ $TASK != "" ]]; then
		printf "${OVERWRITE}${LGREEN} [✓]  ${LGREEN}${TASK}\n"
	fi
	# set new task title and print
	TASK=$1
	printf "${LBLACK} [ ]  ${TASK} \n${LRED}"
}

# _cmd performs commands with error checking
function _cmd {
	#create log if it doesn't exist
	if ! [[ -f $DOTFILES_LOG ]]; then
		touch $DOTFILES_LOG
	fi
	# empty conduro.log
	>$DOTFILES_LOG
	# hide stdout, on error we print and exit
	if eval "$1" 1>/dev/null 2>$DOTFILES_LOG; then
		return 0 # success
	fi
	# read error from log and add spacing
	printf "${OVERWRITE}${LRED} [X]  ${TASK}${LRED}\n"
	while read line; do
		printf "      ${line}\n"
	done <$DOTFILES_LOG
	printf "\n"
	# remove log file
	rm $DOTFILES_LOG
	# exit installation
	exit 1
}

function _clear_task {
	TASK=""
}

function _task_done {
	printf "${OVERWRITE}${LGREEN} [✓]  ${LGREEN}${TASK}\n"
	_clear_task
}

function ubuntu_setup() {
	if ! dpkg -s ansible >/dev/null 2>&1; then
		_task "Instalando Ansible"
		_cmd "sudo apt-get update"
		_cmd "sudo apt-get install -y software-properties-common"
		_cmd "sudo apt-add-repository -y ppa:ansible/ansible"
		_cmd "sudo apt-get update"
		_cmd "sudo apt-get install -y ansible"
		_cmd "sudo apt-get install python3-argcomplete"
		_cmd "sudo activate-global-python-argcomplete3"
	fi
	if ! dpkg -s python3 >/dev/null 2>&1; then
		_task "Instalando Python3"
		_cmd "sudo apt-get install -y python3"
	fi
	if ! dpkg -s python3-pip >/dev/null 2>&1; then
		_task "Instalando Python3 Pip"
		_cmd "sudo apt-get install -y python3-pip"
	fi
}

update_ansible_galaxy() {
	local os=$1
	local os_requirements=""
	_task "Atualizando Ansible Galaxy"
	if [ -f "$DOTFILES_DIR/requirements.yml" ]; then
		_task "${OVERWRITE}Updating Ansible Galaxy with OS Config: $os"
		os_requirements="$DOTFILES_DIR/requirements.yml"
	fi
	_cmd "ansible-galaxy install -r $DOTFILES_DIR/requirements.yml $os_requirements"
}

source /etc/os-release
_task "Inicializando a instalação para a distro: $ID"
case $ID in
ubuntu)
	ubuntu_setup
	;;
*)
	_task "Distro não suportada"
	_cmd "Distro não suportada"
	;;
esac

if ! [[ -f "$SSH_DIR/authorized_keys" ]]; then
	_task "Gerando chaves SSH"
	_cmd "mkdir -p $SSH_DIR"
	_cmd "chmod 700 $SSH_DIR"
	_cmd "ssh-keygen -b 4096 -t rsa -f $SSH_DIR/id_rsa -N '' -C $USER@$HOSTNAME"
	_cmd "cat $SSH_DIR/id_rsa.pub >> $SSH_DIR/authorized_keys"
fi

if ! [[ -d "$DOTFILES_DIR" ]]; then
	_task "Clonando repositório"
	_cmd "git clone --quiet https://github.com/luiseduardobatista/dotfiles.git $DOTFILES_DIR"
else
	_task "Atualizando repositório"
	_cmd "git -C $DOTFILES_DIR pull --quiet"
fi

pushd "$DOTFILES_DIR" 2>&1 >/dev/null
update_ansible_galaxy $ID

_task "Rodando playbook"
_task_done
if [[ -f $VAULT_SECRET ]]; then
	ansible-playbook --extra-vars "@$VALUES_DIR/values.yaml" --vault-password-file $VAULT_SECRET "$DOTFILES_DIR/main.yml" "$@"
else
	ansible-playbook --extra-vars "@$VALUES_DIR/values.yaml" "$DOTFILES_DIR/main.yml" "$@"
fi

popd 2>&1 >/dev/null

if ! [[ -f "$IS_FIRST_RUN" ]]; then
	echo -e "${CHECK_MARK} ${GREEN}Primeira execução completa!${NC}"
	echo -e "${ARROW} ${CYAN}Por favor reinicie o computador para concluir a instalação.${NC}"
	touch "$IS_FIRST_RUN"
fi

# vi:ft=sh:
